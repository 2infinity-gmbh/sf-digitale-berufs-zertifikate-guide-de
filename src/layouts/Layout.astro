---
interface Props {
	title: string;
	description: string;
	canonical?: string;
	ogImage?: string;
}

const { title, description, canonical, ogImage } = Astro.props;
const canonicalURL = canonical || new URL(Astro.url.pathname, Astro.site).toString();
const ogImageURL = ogImage || new URL('/og-image.jpg', Astro.site).toString();

const schema = {
	"@context": "https://schema.org",
	"@graph": [
		{
			"@type": "WebSite",
			"@id": "https://digitale-berufs-zertifikate-guide.de/#website",
			"url": "https://digitale-berufs-zertifikate-guide.de/",
			"name": "Digitale Berufs Zertifikate Guide",
			"description": "Ihr umfassender Ratgeber für digitale Berufszertifikate in Deutschland",
			"inLanguage": "de-DE"
		},
		{
			"@type": "Organization",
			"@id": "https://digitale-berufs-zertifikate-guide.de/#organization",
			"name": "Digitale Berufs Zertifikate Guide",
			"url": "https://digitale-berufs-zertifikate-guide.de/",
			"logo": {
				"@type": "ImageObject",
				"url": "https://digitale-berufs-zertifikate-guide.de/logo.png"
			}
		}
	]
};
---

<!doctype html>
<html lang="de">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />

		<!-- SEO Meta Tags -->
		<title>{title}</title>
		<meta name="description" content={description} />
		<link rel="canonical" href={canonicalURL} />

		<!-- Open Graph -->
		<meta property="og:type" content="website" />
		<meta property="og:url" content={canonicalURL} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={ogImageURL} />
		<meta property="og:locale" content="de_DE" />

		<!-- Twitter Card -->
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={ogImageURL} />

		<!-- Structured Data -->
		<script type="application/ld+json" set:html={JSON.stringify(schema)} />

		<!-- Analytics -->
		<script defer data-domain="digitale-berufs-zertifikate-guide.de" src="https://plausible.io/js/script.js"></script>
	</head>
	<body class="min-h-screen flex flex-col bg-gray-50">
		<!-- Header -->
		<header class="bg-white shadow-sm border-b border-gray-200">
			<nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
				<div class="flex justify-between items-center h-16">
					<div class="flex-shrink-0">
						<a href="/" class="text-xl font-bold text-blue-700 hover:text-blue-800 transition">
							Digitale Berufs Zertifikate Guide
						</a>
					</div>
					<div class="hidden md:flex space-x-8">
						<a href="/" class="text-gray-700 hover:text-blue-700 transition px-3 py-2">Startseite</a>
						<a href="/blog" class="text-gray-700 hover:text-blue-700 transition px-3 py-2">Ratgeber</a>
						<a href="/impressum" class="text-gray-700 hover:text-blue-700 transition px-3 py-2">Impressum</a>
						<a href="/datenschutz" class="text-gray-700 hover:text-blue-700 transition px-3 py-2">Datenschutz</a>
					</div>
					<button class="md:hidden text-gray-700" aria-label="Menü öffnen">
						<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
						</svg>
					</button>
				</div>
			</nav>
		</header>

		<!-- Ad Space - Header -->
		<div class="bg-gray-100 border-y border-gray-200">
			<div class="max-w-7xl mx-auto px-4 py-2">
				<div class="h-24 flex items-center justify-center bg-white border border-dashed border-gray-300 text-gray-400 text-sm">
					Werbefläche (728x90)
				</div>
			</div>
		</div>

		<!-- Main Content -->
		<main class="flex-grow max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 w-full">
			<slot />
		</main>

		<!-- Footer -->
		<footer class="bg-gray-800 text-white mt-auto">
			<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
				<div class="grid grid-cols-1 md:grid-cols-3 gap-8">
					<div>
						<h3 class="text-lg font-semibold mb-4">Digitale Berufs Zertifikate Guide</h3>
						<p class="text-gray-300 text-sm">
							Ihr vertrauenswürdiger Ratgeber für digitale Berufszertifikate, Online-Qualifikationen und berufliche Weiterbildung in Deutschland.
						</p>
					</div>
					<div>
						<h3 class="text-lg font-semibold mb-4">Navigation</h3>
						<ul class="space-y-2 text-sm">
							<li><a href="/" class="text-gray-300 hover:text-white transition">Startseite</a></li>
							<li><a href="/blog" class="text-gray-300 hover:text-white transition">Ratgeber</a></li>
							<li><a href="/impressum" class="text-gray-300 hover:text-white transition">Impressum</a></li>
							<li><a href="/datenschutz" class="text-gray-300 hover:text-white transition">Datenschutz</a></li>
						</ul>
					</div>
					<div>
						<h3 class="text-lg font-semibold mb-4">Rechtliches</h3>
						<ul class="space-y-2 text-sm">
							<li><a href="/impressum" class="text-gray-300 hover:text-white transition">Impressum</a></li>
							<li><a href="/datenschutz" class="text-gray-300 hover:text-white transition">Datenschutzerklärung</a></li>
						</ul>
					</div>
				</div>
				<div class="border-t border-gray-700 mt-8 pt-8 text-center text-sm text-gray-400">
					<p>&copy; {new Date().getFullYear()} Digitale Berufs Zertifikate Guide. Alle Rechte vorbehalten.</p>
				</div>
			</div>
		</footer>
	</body>
</html>
